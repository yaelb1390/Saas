APP_NAME="BM Business OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_TIMEZONE=America/Santo_Domingo
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL. En local vía Docker: host=postgres. En prod: apuntar al host de Supabase.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bmbusinessos
DB_USERNAME=bmos
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Cloudflare R2 (storage S3-compatible) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto

# --- n8n (automatización) ---
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_SECRET=

# --- Evolution API (WhatsApp) ---
# Vacío = modo registro (no se envía nada, solo se guarda la conversación).
# Para operar en vivo: docker compose --profile whatsapp up -d evolution
#   EVOLUTION_BASE_URL=http://evolution:8080   (nombre del servicio en la red de Docker)
#   EVOLUTION_API_KEY debe coincidir con AUTHENTICATION_API_KEY del contenedor.
# El nombre de la instancia es el slug de la empresa activa (una línea por empresa);
# EVOLUTION_INSTANCE solo se usa como reserva si no hay empresa activa.
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_WEBHOOK_URL=http://web/webhooks/evolution

# --- IA (OpenAI / Claude) ---
AI_DEFAULT_PROVIDER=claude
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- DGII (facturación fiscal RD) ---
DGII_ENVIRONMENT=testing
DGII_CERT_PATH=
DGII_CERT_PASSWORD=
